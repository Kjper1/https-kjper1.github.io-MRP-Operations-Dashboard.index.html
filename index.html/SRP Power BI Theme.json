{
  "name": "SRP Operations Center",
  "dataColors": [
    "#275DAD",
    "#2E7D32",
    "#F9A825",
    "#C62828",
    "#546E7A",
    "#6A4C93",
    "#00838F",
    "#8D6E63"
  ],
  "background": "#F7F8FA",
  "foreground": "#1F2933",
  "tableAccent": "#275DAD",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#D9DEE7"
              }
            },
            "radius": 4
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    }
  }
}
